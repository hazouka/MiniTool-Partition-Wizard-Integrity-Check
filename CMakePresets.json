{
  "version": 8,
  "configurePresets": [
    {
      "name": "Ninja-MSVC",
      "displayName": "Ninja with MSVC cl.exe",

      "generator": "Ninja",

      "binaryDir": "${sourceDir}/build/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },

      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },

      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}",

        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    }
  ]
}
